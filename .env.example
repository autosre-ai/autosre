# OpenSRE Configuration
# Copy to .env and fill in your values

# ====================
# LLM Provider
# ====================
# Options: ollama (local), openai, anthropic
OPENSRE_LLM_PROVIDER=ollama

# Ollama (recommended for local/private deployments)
OPENSRE_OLLAMA_HOST=http://localhost:11434
OPENSRE_OLLAMA_MODEL=llama3.1:8b

# OpenAI (uncomment if using)
# OPENSRE_LLM_PROVIDER=openai
# OPENSRE_OPENAI_API_KEY=sk-your-key-here
# OPENSRE_OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic (uncomment if using)
# OPENSRE_LLM_PROVIDER=anthropic
# OPENSRE_ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENSRE_ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ====================
# Infrastructure
# ====================
# Prometheus
OPENSRE_PROMETHEUS_URL=http://prometheus:9090

# Kubernetes
# Leave empty to use default kubeconfig (~/.kube/config)
# OPENSRE_KUBECONFIG=~/.kube/config
OPENSRE_K8S_NAMESPACES=default,production

# Loki (optional, for log correlation)
# OPENSRE_LOKI_URL=http://loki:3100

# ====================
# Slack Integration
# ====================
# Get these from your Slack app: https://api.slack.com/apps
OPENSRE_SLACK_BOT_TOKEN=xoxb-your-bot-token
OPENSRE_SLACK_SIGNING_SECRET=your-signing-secret
OPENSRE_SLACK_CHANNEL=#incidents

# ====================
# PagerDuty (optional)
# ====================
# OPENSRE_PAGERDUTY_API_KEY=your-api-key

# ====================
# Agent Behavior
# ====================
# Require human approval for actions (recommended)
OPENSRE_REQUIRE_APPROVAL=true

# Auto-approve low-risk actions (e.g., get logs, describe pods)
OPENSRE_AUTO_APPROVE_LOW_RISK=false

# Minimum confidence for root cause determination (0.0-1.0)
OPENSRE_CONFIDENCE_THRESHOLD=0.7

# Maximum investigation iterations
OPENSRE_MAX_ITERATIONS=10

# Investigation timeout in seconds
OPENSRE_TIMEOUT_SECONDS=300

# ====================
# Runbooks
# ====================
# Path to your runbook markdown files
OPENSRE_RUNBOOKS_PATH=./runbooks

# ====================
# Logging
# ====================
OPENSRE_LOG_LEVEL=INFO
OPENSRE_LOG_FORMAT=json
